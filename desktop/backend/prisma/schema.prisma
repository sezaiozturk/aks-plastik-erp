generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  role       String   @default("user") // "admin" or "user"
  department String?
  employeeId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  passwordResetTokens PasswordResetToken[]
  orders              Order[]
  employee            Employee? @relation(fields: [employeeId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  initials     String

  // Identity
  customerType   String  @default("Company")
  fullName       String?
  taxId          String?
  taxOffice      String?
  ticaretSicil   String?
  mersisNo       String?
  bolge          String?
  cariTip        String?
  istatistikGrup String?
  mukellefTipi   String?

  // Contact
  contact      String   @default("—")
  contactRole  String   @default("—")
  contactName  String?
  contactPhone String?
  contactEmail String?
  contactPersonPhone           String?
  contactPersonEmail           String?
  contactNamePurchasing        String?
  contactPersonPhonePurchasing String?
  contactPersonEmailPurchasing String?
  contactPosition              String?

  // Address
  region     String?
  address    String?
  city       String?
  district   String?
  postalCode String?
  country    String?
  phone      String?
  email      String?

  // Location
  latitude  Float?
  longitude Float?

  // Tax & e-Documents
  eInvoiceStatus  Boolean @default(false)
  eArchiveStatus  Boolean @default(false)
  eDispatchStatus Boolean @default(false)
  invoiceScenario String  @default("Basic")

  // Financial
  accountCode String?
  accountType String  @default("Customer")
  currency    String  @default("TRY")
  paymentTerm String?
  creditLimit Float?

  // Bank
  bankName      String?
  iban          String?
  branchCode    String?
  accountHolder String?

  // Invoicing & Payment
  invoiceType   String?
  paymentMethod String?
  paymentTerms  String?

  // Optional
  industry         String?
  customerCategory String?
  salesRepName     String?
  notes            String?
  gdprConsent      Boolean @default(false)

  // Stats
  totalOrders  Int      @default(0)
  activeOrders Int      @default(0)
  badge        String   @default("0 OPEN")
  badgeType    String   @default("clear")
  flagged      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reports    Report[]
  siteVisits SiteVisit[]
  orders     Order[]
}

model Report {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  description String    @default("")
  priority    String    @default("Low")
  column      String    @default("open")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?
}

model SiteVisit {
  id        String   @id @default(cuid())
  code      String   @unique
  title     String
  location  String   @default("")
  date      String
  time      String
  status    String   @default("Scheduled")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  stockNo     String   @default("")
  name        String
  description String   @default("")
  category    String   @default("General")
  unit        String   @default("pcs")
  currency    String   @default("USD")
  price       Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
}

model Employee {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  initials     String
  department   String   @default("General")
  position     String   @default("")
  phone        String?
  email        String?
  salary       Float    @default(0)
  status       String   @default("Active")
  hireDate     String?
  supervisorId String?
  isManager    Boolean  @default(false)
  photo        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supervisor   Employee?  @relation("EmployeeSupervisor", fields: [supervisorId], references: [id])
  subordinates Employee[] @relation("EmployeeSupervisor")

  orders        Order[]
  reports       Report[]
  siteVisits    SiteVisit[]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  user          User?
}

model Order {
  id          String   @id @default(cuid())
  code        String   @unique
  status      String   @default("Draft")
  vat         Float    @default(0)
  totalAmount Float    @default(0)
  notes       String   @default("")
  shipmentType  String   @default("")
  paymentMethod String   @default("")
  orderDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id])
  customerId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  employeeId  String?
  salesRep    User?     @relation(fields: [salesRepId], references: [id])
  salesRepId  String?

  items          OrderItem[]
  financeRecords FinanceRecord[]
}

model OrderItem {
  id          String  @id @default(cuid())
  productName String
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  currency    String  @default("USD")
  vat         Float   @default(0)

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
}

model UserRole {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model RolePermission {
  id   Int    @id @default(autoincrement())
  role String
  page String

  @@unique([role, page])
}

model RoleStatusPermission {
  id     Int    @id @default(autoincrement())
  role   String
  status String

  @@unique([role, status])
}

model Machine {
  id                  Int                        @id @default(autoincrement())
  code                String                     @unique
  name                String
  manufacturer        String                     @default("")
  manufacturerCountry String                     @default("")
  manufacturerContact String                     @default("")
  productionYear      Int?
  warrantyExpiry      String                     @default("")
  status              String                     @default("Active")
  location            String                     @default("")
  nextMaintenanceDue  String                     @default("")
  notes               String                     @default("")
  manualPath          String                     @default("")
  manualName          String                     @default("")
  createdAt           DateTime                   @default(now())
  maintenanceRecords  MachineMaintenanceRecord[]
  monthlyMaintenance  MachineMonthlyMaintenance[]
}

model MachineMaintenanceRecord {
  id          Int      @id @default(autoincrement())
  machineId   Int
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date        String
  type        String   @default("Preventive")
  description String   @default("")
  technician  String   @default("")
  cost        Float    @default(0)
  currency    String   @default("USD")
  nextDue     String   @default("")
  createdAt   DateTime @default(now())
}

model MachineMonthlyMaintenance {
  id          Int      @id @default(autoincrement())
  machineId   Int
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  description String   @default("")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model FinanceRecord {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String
  category    String   @default("General")
  amount      Float    @default(0)
  currency    String   @default("USD")
  date        String
  reference   String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?
}

model Attendance {
  id         String   @id @default(cuid())
  date       String
  checkIn    String?
  checkOut   String?
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  type       String   @default("Annual")
  startDate  String
  endDate    String
  days       Int      @default(1)
  reason     String   @default("")
  status     String   @default("Pending")
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
}

model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  category     String   @default("General")
  contactName  String   @default("")
  contactPhone String   @default("")
  contactEmail String   @default("")
  address      String   @default("")
  country      String   @default("")
  currency     String   @default("USD")
  status       String   @default("Active")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotations     PurchaseQuotation[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseRequest {
  id              String   @id @default(cuid())
  code            String   @unique
  title           String
  description     String   @default("")
  department      String   @default("")
  requestedBy     String   @default("")
  priority        String   @default("Medium")
  category        String   @default("General")
  estimatedAmount Float    @default(0)
  currency        String   @default("TRY")
  budgetCode      String   @default("")
  notes           String   @default("")
  status          String   @default("Request")
  budgetApproved  Boolean  @default(false)
  budgetNotes     String   @default("")
  approvedBy      String   @default("")
  approvedAt      String?
  rejectionReason String   @default("")
  receivedDate    String?
  receivedBy      String   @default("")
  qcResult        String   @default("")
  qcNotes         String   @default("")
  qcDate          String?
  invoiceNo       String   @default("")
  invoiceDate     String?
  invoiceAmount   Float    @default(0)
  invoiceMatched  Boolean  @default(false)
  paymentDueDate  String?
  paymentStatus   String   @default("")
  paymentDate     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quotations    PurchaseQuotation[]
  purchaseOrder PurchaseOrder?
}

model PurchaseQuotation {
  id            String   @id @default(cuid())
  supplierName  String   @default("")
  quotationNo   String   @default("")
  quotationDate String   @default("")
  amount        Float    @default(0)
  currency      String   @default("TRY")
  vat           Float    @default(0)
  deliveryDays  Int      @default(0)
  paymentTerms  String   @default("")
  warranty      String   @default("")
  notes         String   @default("")
  selected      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request    PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId  String
  supplier   Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId String?
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  code         String   @unique
  status       String   @default("Draft")
  currency     String   @default("USD")
  vat          Float    @default(0)
  totalAmount  Float    @default(0)
  notes        String   @default("")
  expectedDate String   @default("")
  receivedDate String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier   Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId String?
  request    PurchaseRequest? @relation(fields: [requestId], references: [id])
  requestId  String?          @unique

  items PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  productName     String
  quantity        Int      @default(1)
  unitPrice       Float    @default(0)
  currency        String   @default("USD")
  receivedQty     Int      @default(0)
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  product         Product?      @relation(fields: [productId], references: [id])
  productId       String?
}

model UserStatusPermission {
  id     Int    @id @default(autoincrement())
  userId String
  status String

  @@unique([userId, status])
}

model UserPurchasingStatusPermission {
  id     Int    @id @default(autoincrement())
  userId String
  status String

  @@unique([userId, status])
}
